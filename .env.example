# Copy to .env and edit to override defaults (docker compose auto-loads .env).

# -- Display (GUI viewer) -----------------------------------------------------
DISPLAY=:0

# -- GPU selection ------------------------------------------------------------
# Use "0", "0,1", or "all" to pick which NVIDIA devices the container sees.
NVIDIA_VISIBLE_DEVICES=all

# -- ROS 2 DDS ----------------------------------------------------------------
# Must match the host ROS 2 environment, otherwise discovery silently drops.
ROS_DOMAIN_ID=0
# Default: Cyclone DDS. Set to rmw_fastrtps_cpp to opt into FastDDS — in that
# case run.sh will also export FASTDDS_BUILTIN_TRANSPORTS=UDPv4 (required so
# the SHM transport doesn't break at the container/host UID boundary).
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp

# -- newton_bridge ------------------------------------------------------------
# Robot pack directory (container path). Matches ROBOT=<name> in run.sh.
ROBOT_PACK=/workspace/robots/ur5e

# freerun = sim auto-steps at FREERUN_RATE
# sync    = sim advances one step per /joint_command publish; idle timeout
#           republishes /joint_states so subscribers don't starve
SYNC_MODE=freerun

# realtime = sleep to match physics_dt wall-clock
# max      = step as fast as possible (training mode)
FREERUN_RATE=realtime

# -- Jupyter ------------------------------------------------------------------
JUPYTER_TOKEN=newton
