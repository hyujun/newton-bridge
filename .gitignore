# -- asset cache (populated by scripts/host/fetch_assets.sh) ------------------
assets/_cache/*
!assets/_cache/README.md

# -- pulled robot assets (license-isolated, fetched on demand) ----------------
robots/*/models/

# -- runtime workspace (container writes here) --------------------------------
workspace/outputs/
workspace/models/
workspace/notebooks/.ipynb_checkpoints/

# -- python ------------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/
build/
dist/

# -- editor / env ------------------------------------------------------------
.env
.vscode/
.idea/
.DS_Store

# -- jupyter / rerun ---------------------------------------------------------
*.rrd
.jupyter/
